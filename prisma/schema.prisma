generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  CANCELLED
  EXPIRED
  PAST_DUE
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum LiveClassPurchaseStatus {
  PENDING
  PAID
  FAILED
}

enum ContentSourceType {
  TEXT
  WEB
  PDF
  VIDEO
  AUDIO
  DOCUMENT
  OTHER
}

enum ContentGenerationStatus {
  PROCESSING
  COMPLETED
  FAILED
}

enum DailyContentModule {
  VOCABULARY
  READING
  GRAMMAR
}

enum ExamAccessType {
  FREE
  PREMIUM
  PLAN_INCLUDED
}

enum ExamPublicationStatus {
  DRAFT
  PARSING
  REVIEW
  READY
  PUBLISHED
  ARCHIVED
}

enum ExamTakingMode {
  ONE_BY_ONE
  SECTION_BASED
  OMR_FOCUSED
}

enum ExamSectionType {
  VOCABULARY
  GRAMMAR
  CLOZE_TEST
  SENTENCE_COMPLETION
  TRANSLATION_EN_TO_TR
  TRANSLATION_TR_TO_EN
  PARAGRAPH_COMPLETION
  READING_COMPREHENSION
  DIALOGUE
  CLOSEST_MEANING
  OTHER
}

enum ParseJobStatus {
  QUEUED
  PROCESSING
  NEEDS_REVIEW
  COMPLETED
  FAILED
}

enum QuestionStatus {
  DRAFT
  VERIFIED
  PUBLISHED
  ARCHIVED
}

enum ExplanationSourceType {
  MANUAL
  AI
  HYBRID
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  AUTO_SUBMITTED
  EXPIRED
  CANCELLED
}

enum ReviewBookingStatus {
  PENDING_PAYMENT
  PAID
  SCHEDULED
  COMPLETED
  CANCELLED
  REFUNDED
}

enum ReviewPaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

model User {
  id             String          @id @default(cuid())
  name           String?
  email          String          @unique
  password       String?
  role           UserRole        @default(STUDENT)
  image          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  studentProfile StudentProfile?
  teacherProfile TeacherProfile?
  accounts       Account[]
  sessions       Session[]
  passwordResetTokens PasswordResetToken[]
  subscriptions  Subscription[]
  liveClassPurchases LiveClassPurchase[]
  examPurchases  ExamPurchase[]
  studentFeatureAccess StudentFeatureAccess?
  studentFeatureExamAccesses StudentFeatureExamAccess[]
  dailyContents  StudentDailyContent[]
  examAttempts   ExamAttempt[]
  studentReviewBookings ExamReviewBooking[] @relation("ReviewBookingStudent")
  teacherReviewBookings ExamReviewBooking[] @relation("ReviewBookingTeacher")
  reviewPayments ExamReviewPayment[]
  adminAuditLogs AdminAuditLog[]
}

model StudentProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  targetExam         String?
  targetScore        Int?
  currentLevel       String?
  interestTags       String[] @default([])
  dailyGoalMinutes   Int?
  onboardingComplete Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StudentFeatureAccess {
  id                      String   @id @default(cuid())
  userId                  String   @unique
  hasReadingAccess        Boolean  @default(false)
  hasGrammarAccess        Boolean  @default(false)
  hasVocabAccess          Boolean  @default(false)
  hasExamAccess           Boolean  @default(false)
  hasLiveClassesAccess    Boolean  @default(false)
  hasLiveRecordingsAccess Boolean  @default(false)
  hasContentLibraryAccess Boolean  @default(false)
  hasAIPlannerAccess      Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StudentFeatureExamAccess {
  id           String   @id @default(cuid())
  userId       String
  examModuleId String
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  examModule ExamModule @relation(fields: [examModuleId], references: [id], onDelete: Cascade)

  @@unique([userId, examModuleId])
  @@index([userId])
  @@index([examModuleId])
}

model StudentDailyContent {
  id          String             @id @default(cuid())
  userId      String
  dayKey      String
  moduleKey   DailyContentModule
  contentJson Json
  generatedAt DateTime           @default(now())
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dayKey, moduleKey])
  @@index([userId, dayKey])
}

model TeacherProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  bio       String?
  expertise String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Plan {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  description       String?
  monthlyPrice      Float?
  yearlyPrice       Float?
  includesLiveClass Boolean  @default(false)
  includesAIPlanner Boolean  @default(false)
  includesReading   Boolean  @default(true)
  includesGrammar   Boolean  @default(true)
  includesVocab     Boolean  @default(true)
  includesExam      Boolean  @default(false)
  isStandaloneExamProduct Boolean @default(false)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  subscriptions Subscription[]
  examModules   PlanExamModule[]
}

model PlanExamModule {
  id           String     @id @default(cuid())
  planId       String
  examModuleId String
  createdAt    DateTime   @default(now())

  plan       Plan       @relation(fields: [planId], references: [id], onDelete: Cascade)
  examModule ExamModule @relation(fields: [examModuleId], references: [id], onDelete: Cascade)

  @@unique([planId, examModuleId])
  @@index([planId])
  @@index([examModuleId])
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  surname   String
  phone     String
  email     String
  plan      String
  createdAt DateTime @default(now())
}

model Subscription {
  id           String             @id @default(cuid())
  userId       String
  planId       String
  status       SubscriptionStatus @default(TRIALING)
  billingCycle BillingCycle
  startDate    DateTime
  endDate      DateTime?
  autoRenew    Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)
}

model VocabularyWord {
  id              String   @id @default(cuid())
  word            String   @unique
  partOfSpeech    String?
  cefrLevel       String?
  meaningTr       String?
  meaningEn       String?
  exampleSentence String?
  pronunciation   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Reading {
  id              String   @id @default(cuid())
  title           String
  sourceName      String?
  sourceUrl       String?
  content         String   @db.Text
  summary         String?  @db.Text
  difficultyLevel String?
  category        String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model GrammarTopic {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  description     String?  @db.Text
  difficultyLevel String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  questions GrammarQuestion[]
}

model GrammarQuestion {
  id            String   @id @default(cuid())
  topicId       String
  questionText  String   @db.Text
  optionsJson   String   @db.Text
  correctAnswer String
  explanation   String?  @db.Text
  difficulty    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  topic GrammarTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
}

model LiveClass {
  id              String   @id @default(cuid())
  title           String
  description     String?  @db.Text
  topicOutline    String?  @db.Text
  singlePrice     Float?
  scheduledAt     DateTime
  durationMinutes Int
  meetingLink     String?
  recordingUrl    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  purchases LiveClassPurchase[]
}

model LiveClassPurchase {
  id              String                  @id @default(cuid())
  liveClassId     String
  userId          String?
  status          LiveClassPurchaseStatus @default(PENDING)
  amount          Float
  fullName        String
  email           String
  phone           String
  referenceId     String                  @unique
  provider        String                  @default("paytr")
  providerMessage String?
  paidAt          DateTime?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  liveClass LiveClass @relation(fields: [liveClassId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model SeoConfig {
  id              String   @id @default(cuid())
  pageKey         String   @unique  // e.g. "home", "pricing", "live-classes"
  pageLabel       String            // Human readable: "Ana Sayfa"
  pagePath        String?
  title           String?
  description     String?  @db.Text
  primaryKeyword  String?
  secondaryKeywords String? @db.Text
  searchIntent    String?
  keywords        String?  @db.Text
  ogTitle         String?
  ogDescription   String?  @db.Text
  ogImage         String?
  ogType          String?
  twitterTitle    String?
  twitterDescription String? @db.Text
  twitterImage    String?
  twitterCard     String?
  canonicalUrl    String?
  noIndex         Boolean  @default(false)
  noFollow        Boolean  @default(false)
  noArchive       Boolean  @default(false)
  noSnippet       Boolean  @default(false)
  maxSnippet      Int?
  maxVideoPreview Int?
  maxImagePreview String?
  robotsDirectives String? @db.Text
  breadcrumbTitle String?
  schemaType      String?
  schemaMarkup    String?  @db.Text  // JSON-LD string
  sitemapPriority Float?
  changeFrequency String?
  customHeadTags  String?  @db.Text
  contentNotes    String?  @db.Text
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())
}

model ContentSource {
  id           String            @id @default(cuid())
  title        String
  sourceType   ContentSourceType
  sourceUrl    String?
  mimeType     String?
  rawText      String?           @db.Text
  extractedText String           @db.Text
  styleNotes   String?           @db.Text
  tags         String[]          @default([])
  metadataJson Json?
  createdById  String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model ContentGenerationRun {
  id                 String                  @id @default(cuid())
  title              String
  status             ContentGenerationStatus @default(COMPLETED)
  isApproved         Boolean                 @default(false)
  approvedAt         DateTime?
  approvedById       String?
  isPublished        Boolean                 @default(false)
  publishedAt        DateTime?
  publishedById      String?
  itemType           String
  outputFormat       String
  itemCount          Int
  sourceIds          String[]                @default([])
  sourceSnapshotJson Json?
  styleAnalysis      String?                 @db.Text
  instructions       String?                 @db.Text
  generatedItemsJson Json?
  generatedText      String?                 @db.Text
  createdById        String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
}

model ExamModule {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  examType        String
  cefrLevel       String?
  durationMinutes Int      @default(45)
  questionCount   Int      @default(20)
  description     String?  @db.Text
  instructions    String?  @db.Text
  marketplaceTitle String?
  marketplaceDescription String? @db.Text
  coverImageUrl   String?
  price           Float?
  isForSale       Boolean  @default(false)
  contentJson     Json
  subtitle        String?
  sourceLabel     String?
  examSeries      String?
  yearLabel       String?
  tags            String[] @default([])
  estimatedDifficulty String?
  targetStudentLevel String?
  accessType      ExamAccessType @default(PREMIUM)
  publicationStatus ExamPublicationStatus @default(DRAFT)
  aiExplanationEnabled Boolean @default(true)
  lessonReviewPrice Float?
  lessonCurrency  String   @default("TRY")
  bookingAvailabilityJson Json?
  retakeRulesJson Json?
  scoreVisibilityRulesJson Json?
  explanationVisibilityJson Json?
  randomizeQuestionOrder Boolean @default(false)
  randomizeOptions Boolean @default(false)
  showTimeWarnings Boolean @default(true)
  autoSubmitOnTimeout Boolean @default(true)
  allowPause      Boolean  @default(false)
  takingMode      ExamTakingMode @default(OMR_FOCUSED)
  pdfOriginalAssetId String?
  activeVersionId String?
  isPublished     Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  purchases       ExamPurchase[]
  plans           PlanExamModule[]
  studentAccesses StudentFeatureExamAccess[]
  versions        ExamVersion[]
  sections        ExamSection[]
  passageGroups   ExamPassageGroup[]
  questions       ExamQuestion[]
  attempts        ExamAttempt[]
  pricingRules    ExamPricingRule[]
  reviewBookings  ExamReviewBooking[]
}

model ExamVersion {
  id                String   @id @default(cuid())
  examModuleId      String
  versionNumber     Int
  label             String?
  sourcePdfAssetId  String?
  parseJobStatus    ParseJobStatus @default(QUEUED)
  parseConfidence   Float?
  parsedSnapshotJson Json?
  adminNotes        String?  @db.Text
  isActive          Boolean  @default(false)
  createdById       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  examModule   ExamModule          @relation(fields: [examModuleId], references: [id], onDelete: Cascade)
  assets       ExamAsset[]
  parseJobs    ExamParseJob[]
  sections     ExamSection[]
  passageGroups ExamPassageGroup[]
  questions    ExamQuestion[]
  attempts     ExamAttempt[]

  @@unique([examModuleId, versionNumber])
  @@index([examModuleId, isActive])
}

model ExamAsset {
  id              String   @id @default(cuid())
  examVersionId   String
  assetType       String
  storageKey      String
  originalFileName String?
  mimeType        String
  fileSizeBytes   Int?
  checksum        String?
  pageCount       Int?
  width           Int?
  height          Int?
  metadataJson    Json?
  createdAt       DateTime @default(now())

  examVersion ExamVersion @relation(fields: [examVersionId], references: [id], onDelete: Cascade)

  @@index([examVersionId, assetType])
}

model ExamParseJob {
  id               String   @id @default(cuid())
  examVersionId    String
  status           ParseJobStatus @default(QUEUED)
  provider         String?
  startedAt        DateTime?
  completedAt      DateTime?
  errorMessage     String?  @db.Text
  rawOutputJson    Json?
  lowConfidenceCount Int    @default(0)
  createdById      String?
  createdAt        DateTime @default(now())

  examVersion ExamVersion @relation(fields: [examVersionId], references: [id], onDelete: Cascade)

  @@index([examVersionId, status])
}

model ExamSection {
  id                String   @id @default(cuid())
  examModuleId      String
  examVersionId     String
  sectionType       ExamSectionType
  title             String
  description       String?  @db.Text
  displayOrder      Int
  questionStartNumber Int?
  questionEndNumber Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  examModule    ExamModule      @relation(fields: [examModuleId], references: [id], onDelete: Cascade)
  examVersion   ExamVersion     @relation(fields: [examVersionId], references: [id], onDelete: Cascade)
  questions     ExamQuestion[]
  passageGroups ExamPassageGroup[]

  @@index([examModuleId, displayOrder])
  @@index([examVersionId, displayOrder])
}

model ExamPassageGroup {
  id              String   @id @default(cuid())
  examModuleId    String
  examVersionId   String
  sectionId       String
  title           String?
  passageText     String?  @db.Text
  imageAssetId    String?
  sourcePageNumber Int?
  sourceBoundsJson Json?
  displayOrder    Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  examModule  ExamModule      @relation(fields: [examModuleId], references: [id], onDelete: Cascade)
  examVersion ExamVersion     @relation(fields: [examVersionId], references: [id], onDelete: Cascade)
  section     ExamSection     @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  questions   ExamQuestion[]

  @@index([examVersionId, sectionId, displayOrder])
}

model ExamQuestion {
  id                 String   @id @default(cuid())
  examModuleId       String
  examVersionId      String
  sectionId          String
  passageGroupId     String?
  questionNumber     Int
  displayOrder       Int
  sectionType        ExamSectionType
  questionText       String   @db.Text
  optionA            String   @db.Text
  optionB            String   @db.Text
  optionC            String   @db.Text
  optionD            String   @db.Text
  optionE            String   @db.Text
  correctAnswer      String
  explanationSourceType ExplanationSourceType @default(AI)
  manualExplanation  String?  @db.Text
  imageAssetId       String?
  sourcePageNumber   Int?
  sourceBoundsJson   Json?
  parseConfidence    Float?
  status             QuestionStatus @default(DRAFT)
  isVerified         Boolean  @default(false)
  topicTags          String[] @default([])
  difficultyLabel    String?
  createdById        String?
  updatedById        String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  examModule   ExamModule         @relation(fields: [examModuleId], references: [id], onDelete: Cascade)
  examVersion  ExamVersion        @relation(fields: [examVersionId], references: [id], onDelete: Cascade)
  section      ExamSection        @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  passageGroup ExamPassageGroup?  @relation(fields: [passageGroupId], references: [id], onDelete: SetNull)
  explanations ExamQuestionExplanation[]
  attemptAnswers ExamAttemptAnswer[]

  @@unique([examVersionId, questionNumber])
  @@index([examModuleId, displayOrder])
  @@index([examVersionId, sectionId, displayOrder])
  @@index([passageGroupId])
}

model ExamAttempt {
  id                  String   @id @default(cuid())
  examModuleId        String
  examVersionId       String
  studentId           String
  status              AttemptStatus @default(IN_PROGRESS)
  startedAt           DateTime @default(now())
  expiresAt           DateTime
  submittedAt         DateTime?
  autoSubmitted       Boolean  @default(false)
  durationSecondsUsed Int?
  correctCount        Int      @default(0)
  incorrectCount      Int      @default(0)
  blankCount          Int      @default(0)
  score               Float?
  netScore            Float?
  accuracyPercentage  Float?
  resultLockedAt      DateTime?
  scoreSummaryJson    Json?
  sectionPerformanceJson Json?
  strongestSection    String?
  weakestSection      String?
  metadataJson        Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  examModule  ExamModule    @relation(fields: [examModuleId], references: [id], onDelete: Cascade)
  examVersion ExamVersion   @relation(fields: [examVersionId], references: [id], onDelete: Restrict)
  student     User          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  answers     ExamAttemptAnswer[]
  answerEvents ExamAttemptAnswerEvent[]
  reviewBookings ExamReviewBooking[]

  @@index([studentId, startedAt])
  @@index([examModuleId, studentId])
  @@index([status, expiresAt])
}

model ExamAttemptAnswer {
  id                String   @id @default(cuid())
  attemptId         String
  questionId        String
  selectedAnswer    String?
  isFlaggedForReview Boolean @default(false)
  isCorrect         Boolean?
  firstAnsweredAt   DateTime?
  lastAnsweredAt    DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  attempt  ExamAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question ExamQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([questionId])
}

model ExamAttemptAnswerEvent {
  id                String   @id @default(cuid())
  attemptId         String
  questionId        String
  eventType         String
  previousAnswer    String?
  nextAnswer        String?
  previousFlagState Boolean?
  nextFlagState     Boolean?
  clientTimestamp   DateTime?
  serverTimestamp   DateTime @default(now())
  metadataJson      Json?

  attempt ExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@index([attemptId, serverTimestamp])
}

model ExamQuestionExplanation {
  id              String   @id @default(cuid())
  examQuestionId  String
  languageCode    String   @default("tr")
  sourceType      ExplanationSourceType @default(AI)
  promptVersion   String?
  contentJson     Json
  isActive        Boolean  @default(true)
  generatedAt     DateTime?
  editedById      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  question ExamQuestion @relation(fields: [examQuestionId], references: [id], onDelete: Cascade)

  @@unique([examQuestionId, languageCode, promptVersion])
  @@index([examQuestionId, isActive])
}

model ExamReviewBooking {
  id                String   @id @default(cuid())
  examModuleId      String
  attemptId         String
  studentId         String
  teacherId         String?
  status            ReviewBookingStatus @default(PENDING_PAYMENT)
  durationMinutes   Int      @default(30)
  priceAmount       Float
  currency          String   @default("TRY")
  selectedQuestionIds String[] @default([])
  bookingScope      String   @default("FULL_WRONG_SET")
  scheduledStartAt  DateTime?
  scheduledEndAt    DateTime?
  lessonNotes       String?  @db.Text
  completedAt       DateTime?
  cancelledAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  examModule ExamModule @relation(fields: [examModuleId], references: [id], onDelete: Cascade)
  attempt    ExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  student    User @relation("ReviewBookingStudent", fields: [studentId], references: [id], onDelete: Cascade)
  teacher    User? @relation("ReviewBookingTeacher", fields: [teacherId], references: [id], onDelete: SetNull)
  payments   ExamReviewPayment[]

  @@index([studentId, status])
  @@index([teacherId, scheduledStartAt])
  @@index([attemptId])
}

model ExamReviewPayment {
  id               String   @id @default(cuid())
  bookingId        String
  userId           String
  provider         String
  providerPaymentId String? @unique
  status           ReviewPaymentStatus @default(PENDING)
  amount           Float
  currency         String
  receiptUrl       String?
  providerMessage  String?
  paidAt           DateTime?
  refundedAmount   Float?
  metadataJson     Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  booking ExamReviewBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user    User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([bookingId, status])
}

model ExamPricingRule {
  id            String   @id @default(cuid())
  examModuleId  String?
  ruleType      String
  label         String?
  amount        Float
  currency      String   @default("TRY")
  userSegment   String?
  startsAt      DateTime?
  endsAt        DateTime?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  examModule ExamModule? @relation(fields: [examModuleId], references: [id], onDelete: Cascade)

  @@index([examModuleId, isActive])
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  actorUserId String
  targetType  String
  targetId    String
  action      String
  beforeJson  Json?
  afterJson   Json?
  metadataJson Json?
  createdAt   DateTime @default(now())

  actor User @relation(fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([actorUserId, createdAt])
  @@index([targetType, targetId])
}

model ExamPurchase {
  id              String                  @id @default(cuid())
  examModuleId    String
  userId          String?
  status          LiveClassPurchaseStatus @default(PENDING)
  amount          Float
  fullName        String
  email           String
  phone           String
  referenceId     String                  @unique
  provider        String                  @default("paytr")
  providerMessage String?
  paidAt          DateTime?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  examModule ExamModule @relation(fields: [examModuleId], references: [id], onDelete: Cascade)
  user       User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
}
