generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  CANCELLED
  EXPIRED
  PAST_DUE
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum LiveClassPurchaseStatus {
  PENDING
  PAID
  FAILED
}

enum ContentSourceType {
  TEXT
  WEB
  PDF
  VIDEO
  AUDIO
  DOCUMENT
  OTHER
}

enum ContentGenerationStatus {
  PROCESSING
  COMPLETED
  FAILED
}

enum DailyContentModule {
  VOCABULARY
  READING
  GRAMMAR
}

model User {
  id             String          @id @default(cuid())
  name           String?
  email          String          @unique
  password       String?
  role           UserRole        @default(STUDENT)
  image          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  studentProfile StudentProfile?
  teacherProfile TeacherProfile?
  accounts       Account[]
  sessions       Session[]
  passwordResetTokens PasswordResetToken[]
  subscriptions  Subscription[]
  liveClassPurchases LiveClassPurchase[]
  examPurchases  ExamPurchase[]
  studentFeatureAccess StudentFeatureAccess?
  studentFeatureExamAccesses StudentFeatureExamAccess[]
  dailyContents  StudentDailyContent[]
}

model StudentProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  targetExam         String?
  targetScore        Int?
  currentLevel       String?
  interestTags       String[] @default([])
  dailyGoalMinutes   Int?
  onboardingComplete Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StudentFeatureAccess {
  id                      String   @id @default(cuid())
  userId                  String   @unique
  hasReadingAccess        Boolean  @default(false)
  hasGrammarAccess        Boolean  @default(false)
  hasVocabAccess          Boolean  @default(false)
  hasExamAccess           Boolean  @default(false)
  hasLiveClassesAccess    Boolean  @default(false)
  hasLiveRecordingsAccess Boolean  @default(false)
  hasContentLibraryAccess Boolean  @default(false)
  hasAIPlannerAccess      Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StudentFeatureExamAccess {
  id           String   @id @default(cuid())
  userId       String
  examModuleId String
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  examModule ExamModule @relation(fields: [examModuleId], references: [id], onDelete: Cascade)

  @@unique([userId, examModuleId])
  @@index([userId])
  @@index([examModuleId])
}

model StudentDailyContent {
  id          String             @id @default(cuid())
  userId      String
  dayKey      String
  moduleKey   DailyContentModule
  contentJson Json
  generatedAt DateTime           @default(now())
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dayKey, moduleKey])
  @@index([userId, dayKey])
}

model TeacherProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  bio       String?
  expertise String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Plan {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  description       String?
  monthlyPrice      Float?
  yearlyPrice       Float?
  includesLiveClass Boolean  @default(false)
  includesAIPlanner Boolean  @default(false)
  includesReading   Boolean  @default(true)
  includesGrammar   Boolean  @default(true)
  includesVocab     Boolean  @default(true)
  includesExam      Boolean  @default(false)
  isStandaloneExamProduct Boolean @default(false)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  subscriptions Subscription[]
  examModules   PlanExamModule[]
}

model PlanExamModule {
  id           String     @id @default(cuid())
  planId       String
  examModuleId String
  createdAt    DateTime   @default(now())

  plan       Plan       @relation(fields: [planId], references: [id], onDelete: Cascade)
  examModule ExamModule @relation(fields: [examModuleId], references: [id], onDelete: Cascade)

  @@unique([planId, examModuleId])
  @@index([planId])
  @@index([examModuleId])
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  surname   String
  phone     String
  email     String
  plan      String
  createdAt DateTime @default(now())
}

model Subscription {
  id           String             @id @default(cuid())
  userId       String
  planId       String
  status       SubscriptionStatus @default(TRIALING)
  billingCycle BillingCycle
  startDate    DateTime
  endDate      DateTime?
  autoRenew    Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)
}

model VocabularyWord {
  id              String   @id @default(cuid())
  word            String   @unique
  partOfSpeech    String?
  cefrLevel       String?
  meaningTr       String?
  meaningEn       String?
  exampleSentence String?
  pronunciation   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Reading {
  id              String   @id @default(cuid())
  title           String
  sourceName      String?
  sourceUrl       String?
  content         String   @db.Text
  summary         String?  @db.Text
  difficultyLevel String?
  category        String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model GrammarTopic {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  description     String?  @db.Text
  difficultyLevel String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  questions GrammarQuestion[]
}

model GrammarQuestion {
  id            String   @id @default(cuid())
  topicId       String
  questionText  String   @db.Text
  optionsJson   String   @db.Text
  correctAnswer String
  explanation   String?  @db.Text
  difficulty    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  topic GrammarTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
}

model LiveClass {
  id              String   @id @default(cuid())
  title           String
  description     String?  @db.Text
  topicOutline    String?  @db.Text
  singlePrice     Float?
  scheduledAt     DateTime
  durationMinutes Int
  meetingLink     String?
  recordingUrl    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  purchases LiveClassPurchase[]
}

model LiveClassPurchase {
  id              String                  @id @default(cuid())
  liveClassId     String
  userId          String?
  status          LiveClassPurchaseStatus @default(PENDING)
  amount          Float
  fullName        String
  email           String
  phone           String
  referenceId     String                  @unique
  provider        String                  @default("paytr")
  providerMessage String?
  paidAt          DateTime?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  liveClass LiveClass @relation(fields: [liveClassId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model SeoConfig {
  id              String   @id @default(cuid())
  pageKey         String   @unique  // e.g. "home", "pricing", "live-classes"
  pageLabel       String            // Human readable: "Ana Sayfa"
  pagePath        String?
  title           String?
  description     String?  @db.Text
  primaryKeyword  String?
  secondaryKeywords String? @db.Text
  searchIntent    String?
  keywords        String?  @db.Text
  ogTitle         String?
  ogDescription   String?  @db.Text
  ogImage         String?
  ogType          String?
  twitterTitle    String?
  twitterDescription String? @db.Text
  twitterImage    String?
  twitterCard     String?
  canonicalUrl    String?
  noIndex         Boolean  @default(false)
  noFollow        Boolean  @default(false)
  noArchive       Boolean  @default(false)
  noSnippet       Boolean  @default(false)
  maxSnippet      Int?
  maxVideoPreview Int?
  maxImagePreview String?
  robotsDirectives String? @db.Text
  breadcrumbTitle String?
  schemaType      String?
  schemaMarkup    String?  @db.Text  // JSON-LD string
  sitemapPriority Float?
  changeFrequency String?
  customHeadTags  String?  @db.Text
  contentNotes    String?  @db.Text
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())
}

model ContentSource {
  id           String            @id @default(cuid())
  title        String
  sourceType   ContentSourceType
  sourceUrl    String?
  mimeType     String?
  rawText      String?           @db.Text
  extractedText String           @db.Text
  styleNotes   String?           @db.Text
  tags         String[]          @default([])
  metadataJson Json?
  createdById  String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model ContentGenerationRun {
  id                 String                  @id @default(cuid())
  title              String
  status             ContentGenerationStatus @default(COMPLETED)
  isApproved         Boolean                 @default(false)
  approvedAt         DateTime?
  approvedById       String?
  isPublished        Boolean                 @default(false)
  publishedAt        DateTime?
  publishedById      String?
  itemType           String
  outputFormat       String
  itemCount          Int
  sourceIds          String[]                @default([])
  sourceSnapshotJson Json?
  styleAnalysis      String?                 @db.Text
  instructions       String?                 @db.Text
  generatedItemsJson Json?
  generatedText      String?                 @db.Text
  createdById        String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
}

model ExamModule {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  examType        String
  cefrLevel       String?
  durationMinutes Int      @default(45)
  questionCount   Int      @default(20)
  description     String?  @db.Text
  instructions    String?  @db.Text
  marketplaceTitle String?
  marketplaceDescription String? @db.Text
  coverImageUrl   String?
  price           Float?
  isForSale       Boolean  @default(false)
  contentJson     Json
  isPublished     Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  purchases       ExamPurchase[]
  plans           PlanExamModule[]
  studentAccesses StudentFeatureExamAccess[]
}

model ExamPurchase {
  id              String                  @id @default(cuid())
  examModuleId    String
  userId          String?
  status          LiveClassPurchaseStatus @default(PENDING)
  amount          Float
  fullName        String
  email           String
  phone           String
  referenceId     String                  @unique
  provider        String                  @default("paytr")
  providerMessage String?
  paidAt          DateTime?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  examModule ExamModule @relation(fields: [examModuleId], references: [id], onDelete: Cascade)
  user       User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
}
